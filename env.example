# Copy to .env and adjust values
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (Supabase) — leave DATABASE_URL empty to use SQLite locally
DATABASE_URL=

# Optional Supabase-style connection (used when DATABASE_URL is set)
# DATABASE_URL=postgresql://user:password@host:5432/lexguard
